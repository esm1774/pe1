# Prevent directory listing
Options -Indexes -MultiViews

# Protect sensitive files
<Files ".htaccess">
    Order allow,deny
    Deny from all
</Files>

<Files "config.php">
    Order allow,deny
    Deny from all
</Files>

<FilesMatch "\.(sql|log|json|md)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Allow access to manifest.json for PWA
<Files "manifest.json">
    Order deny,allow
    Allow from all
</Files>

# Enable URL Rewriting
<IfModule mod_rewrite.c>
    RewriteEngine On

    # 1. Skip rewriting for actual files and directories
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # 2. Fix asset and API paths for school slugs
    # This ensures that requests like /slug/api.php or /slug/css/style.css 
    # are correctly routed to the root files.
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^(?:[^/]+/)?(api\.php|blog\.php|post\.php|index\.php|app\.html|sw\.js|manifest\.json|assets|css|js|icons|vendor|modules|uploads|admin)(.*)$ $1$2 [L,NC,QSA]

    # 3. Rewrite all other requests to app.html (SPA routing)
    # We exclude common actual entry points to avoid loops
    RewriteCond %{REQUEST_URI} !(api\.php|app\.html|sw\.js|manifest\.json|admin|index\.php|register\.html|welcome\.html) [NC]
    RewriteRule ^ app.html [L]
</IfModule>

# Enable Gzip compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# Cache static assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"
    ExpiresByType text/html "access plus 0 seconds"
    ExpiresByType application/json "access plus 0 seconds"
    ExpiresByType application/javascript "access plus 1 week"
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType image/x-icon "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
</IfModule>
